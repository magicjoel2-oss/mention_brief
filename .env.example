# Mention Brief - 환경변수 템플릿
# 이 파일을 .env로 복사하고 실제 값 채워넣기. .env는 .gitignore로 제외됨.

# Anthropic API 키 (요약·권장·우선순위 생성용)
# 발급: https://console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# 사용 모델 (기본: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# 본인 Graph User ID (auth-poc.ps1 STAGE 3에서 확인된 값)
MY_USER_ID=2185dfaa-243b-4541-ba33-1f223e81ccf9

# 멘션 검색 키워드 (본인 UPN의 mailNickname 부분, 보통 @ 앞)
MENTION_KEYWORD=magicjoel

# ---- 페이지 접근 게이트 (방식 2: AES 암호화) ----
# 질문은 페이지에 평문으로 표시됨 (공격자에게 노출돼도 무관)
# 답은 본인만 알아야 함. 16자 이상 unique한 phrase 권장.
# 답 변경 시 npm run reencrypt-data 한 번 돌려야 함 (기존 암호문 재암호화)
MENTION_BRIEF_QUESTION=내가 처음 산 키보드 모델명은? (예시 — 본인 답에 맞춰 교체)
MENTION_BRIEF_ANSWER=Realforce R2 (예시 — 본인이 정한 답으로 교체, 공백·대소문자 정확히)
